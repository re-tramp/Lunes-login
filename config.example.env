# Lunes Host 登录配置
# 复制此文件为 .env 并填入实际值

# 登录页面 URL
LOGIN_URL=https://betadash.lunes.host/login

# 登录 API 端点 (POST /login)
LOGIN_API_URL=https://betadash.lunes.host/login

# 登录后跳转页面
DASHBOARD_URL=https://betadash.lunes.host/dashboard

# 保持会话的 URL
KEEP_ALIVE_URL=https://betadash.lunes.host/cdn-cgi/rum

# 登录凭证 (必须填写)
LOGIN_EMAIL=your_email@example.com
LOGIN_PASSWORD=your_password_here

# Cloudflare Cookies (重要！需要手动获取)
# 在本地浏览器完成 Cloudflare + Turnstile 验证后，从开发者工具获取
CF_CLEARANCE=your_cf_clearance_cookie
SESSION_COOKIE=your_session_cookie

# Turnstile token (如果需要绕过验证码)
# 可通过第三方服务或手动获取后填入
TURNSTILE_TOKEN=your_turnstile_token

# Telegram 通知配置 (可选)
# 1. 创建 Bot: @BotFather 获取 bot token
# 2. 获取 chat_id: @userinfobot 或从群组获取
TG_BOT_TOKEN=your_telegram_bot_token
TG_CHAT_ID=your_telegram_chat_id

# 调试模式 (true/false)
DEBUG=false
